# ==============================================
# Environment Variables Template
# Copy this file to .env and fill in the values
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=finance
ENVIRONMENT=development

# --- Database ---
MYSQL_ROOT_PASSWORD=root
MYSQL_ACCOUNT_DB=account_db

# Legacy DB vars (kept for service-a, service-b placeholders)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=admin
DB_PASSWORD=changeme

# --- Redis ---
REDIS_PASSWORD=

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- JWT ---
JWT_SECRET=finance-secret-key-must-be-at-least-256-bits-long-for-hs256
JWT_EXPIRATION=900000

# --- Eureka ---
EUREKA_USERNAME=admin
EUREKA_PASSWORD=admin123

# --- Service Ports ---
FRONTEND_PORT=3000
GATEWAY_PORT=8080
EUREKA_PORT=8761
ACCOUNT_SERVICE_PORT=8081
SERVICE_A_PORT=5001
SERVICE_B_PORT=5002
